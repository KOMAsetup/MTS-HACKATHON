            { "SKU": "A004", "Discount": "", "Markdown": "" }
          ]
        }
      }
    },
    "reference_code": "_utils.array.new()",
    "eval": {
      "type": "sandbox",
      "expected_contains": ["_utils.array.new", "parsedCsv", "Discount", "Markdown", "ipairs"]
    }
  },
